# ── ReviewPing Lead Scraper — Environment Variables ────────────────────────────

# Google Places API key (required)
# Get one at: https://console.cloud.google.com/apis/credentials
# Enable: Places API (new & old) in your GCP project
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Supabase project credentials (required unless using --dry-run)
# Find these in your Supabase dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Optional: for local edge function development ──────────────────────────────
# Run: supabase functions serve suggest-leads --env-file .env.local
SUPABASE_ANON_KEY=your_anon_key_here
